{
  "name": "vim-mode-visualizer",
  "publisher": "shun0001",
  "displayName": "vim-mode-visualizer",
  "description": "vim-mode-visualizer",
  "version": "0.0.6",
  "engines": {
    "vscode": "^1.108.1"
  },
  "icon": "images/icon.png",
  "license": "MIT",
  "keywords": [
    "vim",
    "vscodevim",
    "cursor",
    "visualizer",
    "mode"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "activationEvents": [
    "*"
  ],
  
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Vim Mode Visualizer",
      "properties": {
        "vimModeVisualizer.enableNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show popup notification when Vim mode changes"
        },
        "vimModeVisualizer.enableInline": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline mode indicator near the cursor"
        },
        "vimModeVisualizer.relativeLinerNumbers": {
          "type": "boolean",
          "default": true,
          "definitions": "Show relative line numbers"
        },
        "vimModeVisualizer.font.color.absolute": {
          "type": "string",
          "default": "#999999",
          "markdownDescription": "Font color of absolute line numbers. Examples: `#999999`, `rgb(128,128,128)`"
        },
        "vimModeVisualizer.font.color.relative": {
          "type": "string",
          "default": "#858585",
          "markdownDescription": "Font color of relative line numbers. Examples: `#858585`, `rgb(100,100,100)`"
        },
        "vimModeVisualizer.font.weight": {
          "type": "string",
          "default": "bold",
          "markdownDescription": "Font boldness. Examples: `normal`, `bold`, `600`"
        },
        "vimModeVisualizer.font.family": {
          "type": "string",
          "default": "Menlo, Monaco, 'Courier New', monospace",
          "markdownDescription": "Font family for line numbers"
        },
        "vimModeVisualizer.text.width": {
          "type": "string",
          "default": "20",
          "markdownDescription": "Text width for each line number (SVG textLength attribute)"
        },
        "vimModeVisualizer.text.height": {
          "type": "string",
          "default": "14",
          "markdownDescription": "Font size for line numbers (in pixels)"
        },
        "vimModeVisualizer.gutter.width": {
          "type": "number",
          "default": 40,
          "markdownDescription": "Gutter SVG width in pixels. Increase to add horizontal space between number columns."
        },
        "vimModeVisualizer.delay": {
          "type": "number",
          "default": 50,
          "markdownDescription": "Delay in milliseconds for throttling line number updates"
        }
      }
    },
    "commands": [
      {
        "command": "vim-mode-visualizer.showMode",
        "title": "Show Vim Mode"
      }
    ],
    "colors": [
      {
        "id": "vimModeVisualizer.normal",
        "description": "Normal mode color",
        "defaults": {
          "dark": "#2196F3",
          "light": "#1976D2"
        }
      },
      {
        "id": "vimModeVisualizer.insert",
        "description": "Insert mode color",
        "defaults": {
          "dark": "#4CAF50",
          "light": "#388E3C"
        }
      },
      {
        "id": "vimModeVisualizer.visual",
        "description": "Visual mode color",
        "defaults": {
          "dark": "#FF9800",
          "light": "#F57C00"
        }
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shunki0001/vim-mode-visualizer"
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.108.1",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
